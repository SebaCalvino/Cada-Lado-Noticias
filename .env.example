# ── IA ──────────────────────────────────────────────────────────────
# Elegí "ollama" (gratis, local) o "anthropic" (pago, mejor calidad)
AI_PROVIDER=ollama

# Solo necesario si AI_PROVIDER=ollama
# URL de Ollama. Desde Docker usá host.docker.internal; local usá localhost
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# Solo necesario si AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── Base de datos ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cadalado:cadalado@db:5432/cadalado
POSTGRES_USER=cadalado
POSTGRES_PASSWORD=cadalado
POSTGRES_DB=cadalado

# ── Backend ─────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
