# ── Database (Supabase Postgres) ─────────────────────────────────────
# Get this from Supabase → Project Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543) for serverless.
# Example: postgresql://postgres.xxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Groq AI ──────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Cron (optional — protects /api/cron/scrape from random calls) ────
CRON_SECRET=
