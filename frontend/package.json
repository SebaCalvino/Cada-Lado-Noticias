{
  "name": "cada-lado-noticias",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "drizzle-kit push:pg",
    "db:generate": "drizzle-kit generate:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "node -e \"require('dotenv').config({path: '../.env.local'}); const { migrate } = require('drizzle-orm/postgres-js/migrator'); const postgres = require('postgres'); const db = require('drizzle-orm/postgres-js').drizzle(postgres(process.env.DATABASE_URL)); migrate(db, {migrationsFolder: '../migrations'}).then(() => process.exit(0)).catch(e => {console.error(e); process.exit(1)});\"",
    "vercel-build": "npm run db:push && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "drizzle-orm": "^0.36.4",
    "framer-motion": "^11.18.2",
    "groq-sdk": "^0.9.1",
    "lucide-react": "^0.383.0",
    "next": "14.2.3",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5"
  }
}
